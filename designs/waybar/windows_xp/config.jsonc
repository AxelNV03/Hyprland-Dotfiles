{
    "include" : [
        "~/.hyprland-dotfiles/core/waybar/modules.jsonc"
    ],
    "layer": "bot", // Waybar at top layer
    "position": "bot", // Waybar position (top|bottom|left|right)
    "height": 30, // Waybar height (to be removed for auto height)
    "spacing": 4, // Gaps between modules (4px)
    "modules-left": [
        "custom/start#windows",
    ],
    "modules-center": [
        
    ],
    "modules-right": [
        "pulseaudio",
        "clock"
    ]
}
